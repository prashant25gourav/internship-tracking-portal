DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=internship_portal

# Admin JWT password (used by /auth/token). Set a strong password in production.
ADMIN_PASSWORD=change_me

# Shared secret for signing JWTs. Keep secret in production.
AUTH_SECRET=change_me_secret

# Optional: MongoDB connection string used by analytics (leave for local development)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=internship_portal
MONGO_ACTIVITY_COLLECTION=activity_logs

# Optional: control Flask debug mode for local runs (True/False)
FLASK_DEBUG=True